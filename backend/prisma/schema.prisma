generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String  @id @default(uuid())
  name             String
  isActive         Boolean @default(true)
  isDefault        Boolean @default(false)
  maxUsers         Int     @default(5)
  maxProjectsTotal Int     @default(20)
  maxStorageMb     Int     @default(500) // SuperAdmin defined storage limit in MB for the entire tenant

  // Custom API Keys
  falApiKey    String?
  openaiApiKey String?
  kieApiKey    String?

  // Pricing Settings (Tenant specific)
  pricePicDrift_5s       Float @default(1)
  pricePicDrift_10s      Float @default(2)
  pricePicDrift_Plus_5s  Float @default(2)
  pricePicDrift_Plus_10s Float @default(3)

  pricePicFX_Standard Float @default(1)
  pricePicFX_Carousel Float @default(3)
  pricePicFX_Batch    Float @default(1)

  priceEditor_Pro     Float @default(4)
  priceEditor_Enhance Float @default(1)
  priceEditor_Convert Float @default(1)

  priceVideoFX1_10s Float @default(4)
  priceVideoFX1_15s Float @default(3)

  priceVideoFX2_4s   Float @default(6)
  priceVideoFX2_8s   Float @default(4)
  priceVideoFX2_12s  Float @default(6)

  priceVideoFX3_4s   Float @default(4)
  priceVideoFX3_6s   Float @default(5)
  priceVideoFX3_8s   Float @default(6)

  priceAsset_DriftPath Float @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfigs   BrandConfig[]
  roiMetrics     ROIMetrics[]
  creditRequests CreditRequest[]
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?

  creditsPicDrift     Float @default(10)
  creditsPicDriftPlus Float @default(10)
  creditsImageFX      Float @default(10)
  creditsVideoFX1     Float @default(10)
  creditsVideoFX2     Float @default(10)
  creditsVideoFX3     Float @default(10)

  creditBalance Float @default(20)

  creditSystem String   @default("COMMERCIAL")
  isDemo       Boolean  @default(false)
  role         String   @default("USER") // SUPERADMIN, ADMIN, USER
  view         String   @default("VISIONLIGHT")
  maxProjects  Int      @default(3)
  adminNotes   String?
  promptFx     Json?    // Stores the user's custom PromptFX setups [{ name: string, prompt: string }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfig    BrandConfig?
  roiMetrics     ROIMetrics?
  creditRequests CreditRequest[]
  storyboard     Json?
}

model Project {
  id         String   @id @default(uuid())
  userId     String
  name       String
  storyboard Json?
  editorState Json?   // Stores FullscreenVideoEditor sequences and audio tracks
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  Post[]
  assets Asset[]
}

model GlobalSettings {
  id String @id @default("singleton")

  pricePicDrift_5s       Float @default(1)
  pricePicDrift_10s      Float @default(2)
  pricePicDrift_Plus_5s  Float @default(2)
  pricePicDrift_Plus_10s Float @default(3)

  pricePicFX_Standard Float @default(1)
  pricePicFX_Carousel Float @default(3)
  pricePicFX_Batch    Float @default(1)

  priceEditor_Pro     Float @default(4)
  priceEditor_Enhance Float @default(1)
  priceEditor_Convert Float @default(1)

  priceVideoFX1_10s Float @default(4)
  priceVideoFX1_15s Float @default(3)

  priceVideoFX2_4s  Float @default(6)
  priceVideoFX2_8s  Float @default(4)
  priceVideoFX2_12s Float @default(6)

  priceVideoFX3_4s Float @default(4)
  priceVideoFX3_6s Float @default(5)
  priceVideoFX3_8s Float @default(6)

  priceAsset_DriftPath Float @default(2)

  updatedAt DateTime @updatedAt
}

model Post {
  id                String   @id @default(uuid())
  userId            String
  title             String?
  prompt            String
  enhancedPrompt    String?
  imageReference    String?
  mediaType         String?
  mediaUrl          String?
  mediaProvider     String?
  generatedEndFrame String?
  status            String   @default("NEW")
  platform          String?
  script            Json?
  generationParams  Json?
  progress          Int      @default(0)
  error             String?
  generationStep    String?
  requiresApproval  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(uuid())
  userId      String
  url         String
  proxyUrl    String?  // Lightweight proxy video URL for editing
  hlsUrl      String?  // HLS stream URL (.m3u8)
  spriteSheetUrl String? // Timeline thumbnail sprite sheet URL
  aspectRatio String
  type        String   @default("IMAGE")
  sizeBytes   Int?     // To track the 500mb limit per project
  createdAt   DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  originalAssetId String?
  originalAsset   Asset?  @relation("AssetHistory", fields: [originalAssetId], references: [id])
  variations      Asset[] @relation("AssetHistory")
}

model BrandConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  companyName    String?
  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ROIMetrics {
  id             String   @id @default(uuid())
  userId         String   @unique
  postsCreated   Int      @default(0)
  timeSaved      Int      @default(0)
  mediaGenerated Int      @default(0)
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditRequest {
  id        String   @id @default(uuid())
  userId    String
  email     String
  name      String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresetPrompt {
  id        String   @id @default(uuid())
  name      String
  prompt    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
