generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String  @id @default(uuid())
  name             String
  isActive         Boolean @default(true)
  isDefault        Boolean @default(false)
  provisioningSource String @default("MANUAL") // MANUAL | BYOK
  entitlementCode    String? // BYOK_TRIAL | PD_APP | VFX_APP | PD_STUDIO | VFX_STUDIO | VFX_STUDIO_AGENCY
  productLine        String? // "ROTATION3D" marks a managed Rotation3D brand org
  routingDomain      String?
  adminPanelLocked   Boolean @default(false)
  renderDailyLimit   Int?
  storageRetentionDays Int?
  provisioningStatus String  @default("READY") // READY | PENDING | ERROR
  tenantPlan       String  @default("PAID")
  trialEndsAt      DateTime?
  maxUsers         Int     @default(5)
  maxProjectsTotal Int     @default(20)
  maxStorageMb     Int     @default(10240) // Platform tenant storage limit in MB for the entire organization (default: 10GB)

  // Custom API Keys
  falApiKey    String?
  openaiApiKey String?
  kieApiKey    String?

  // Pricing Settings (Tenant specific)
  pricePicDrift_5s       Float @default(1)
  pricePicDrift_10s      Float @default(2)
  pricePicDrift_Plus_5s  Float @default(2)
  pricePicDrift_Plus_10s Float @default(3)

  pricePicFX_Standard Float @default(1)
  pricePicFX_Carousel Float @default(3)
  pricePicFX_Batch    Float @default(1)

  priceEditor_Pro     Float @default(4)
  priceEditor_Enhance Float @default(1)
  priceEditor_Convert Float @default(1)

  priceVideoFX1_10s Float @default(4)
  priceVideoFX1_15s Float @default(3)

  priceVideoFX2_4s   Float @default(6)
  priceVideoFX2_8s   Float @default(4)
  priceVideoFX2_12s  Float @default(6)

  priceVideoFX3_4s   Float @default(4)
  priceVideoFX3_6s   Float @default(5)
  priceVideoFX3_8s   Float @default(6)

  priceAsset_DriftPath Float @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfigs   BrandConfig[]
  roiMetrics     ROIMetrics[]
  creditRequests CreditRequest[]
  renderUsages      ByokRenderUsage[]
  webhookEvents     WebhookEvent[]
  entitlement       OrganizationEntitlement?

  rot3dProducts     Rot3dProduct[]
  rot3dSourceImages Rot3dSourceImage[]
  rot3dEvents       Rot3dEvent[]
}

model User {
  id         String  @id @default(uuid())
  authUserId String?
  email      String
  name       String?

  creditsPicDrift     Float @default(10)
  creditsPicDriftPlus Float @default(10)
  creditsImageFX      Float @default(10)
  creditsVideoFX1     Float @default(10)
  creditsVideoFX2     Float @default(10)
  creditsVideoFX3     Float @default(10)

  creditBalance Float @default(20)

  creditSystem String   @default("COMMERCIAL")
  isDemo       Boolean  @default(false)
  role         String   @default("USER") // SUPERADMIN, ADMIN, USER
  view         String   @default("VISIONLIGHT")
  maxProjects  Int      @default(3)
  seatLocked   Boolean  @default(false)
  adminNotes   String?
  promptFx     Json?    // Stores the user's custom PromptFX setups [{ name: string, prompt: string }]
  editorPromptFx Json?  // Isolated PromptFX setups for the asset-library editor (PicFX + Convert tabs) [{ name, prompt }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfig    BrandConfig?
  roiMetrics     ROIMetrics?
  creditRequests CreditRequest[]
  storyboard     Json?

  @@index([authUserId])
  @@index([email])
}

model Project {
  id         String   @id @default(uuid())
  userId     String
  name       String
  storyboard Json?
  editorState Json?   // Stores FullscreenVideoEditor sequences and audio tracks
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  Post[]
  assets Asset[]
}

model GlobalSettings {
  id String @id @default("singleton")

  pricePicDrift_5s       Float @default(1)
  pricePicDrift_10s      Float @default(2)
  pricePicDrift_Plus_5s  Float @default(2)
  pricePicDrift_Plus_10s Float @default(3)

  pricePicFX_Standard Float @default(1)
  pricePicFX_Carousel Float @default(3)
  pricePicFX_Batch    Float @default(1)

  priceEditor_Pro     Float @default(4)
  priceEditor_Enhance Float @default(1)
  priceEditor_Convert Float @default(1)

  priceVideoFX1_10s Float @default(4)
  priceVideoFX1_15s Float @default(3)

  priceVideoFX2_4s  Float @default(6)
  priceVideoFX2_8s  Float @default(4)
  priceVideoFX2_12s Float @default(6)

  priceVideoFX3_4s Float @default(4)
  priceVideoFX3_6s Float @default(5)
  priceVideoFX3_8s Float @default(6)

  priceAsset_DriftPath Float @default(2)

  // Provider USD cost reference per render (managed by SuperAdmin)
  costPicDrift_5s       Float @default(0.35)
  costPicDrift_10s      Float @default(0.7)
  costPicDrift_Plus_5s  Float @default(0.56)
  costPicDrift_Plus_10s Float @default(1.12)

  costPicFX_Standard Float @default(0.08)
  costPicFX_Nano     Float @default(0.12)
  costPicFX_Gpt2     Float @default(0.155)
  costPicFX_Carousel Float @default(0.2)
  costPicFX_Batch    Float @default(0.08)

  costEditor_Pro     Float @default(0.1)
  costEditor_Enhance Float @default(0.12)
  costEditor_Convert Float @default(0.08)

  costVideoFX1_10s Float @default(0.2)
  costVideoFX1_15s Float @default(0.3)

  costVideoFX2_4s  Float @default(1.21)
  costVideoFX2_8s  Float @default(2.42)
  costVideoFX2_12s Float @default(3.63)

  costVideoFX3_4s Float @default(1.6)
  costVideoFX3_6s Float @default(2.4)
  costVideoFX3_8s Float @default(3.2)

  costAsset_DriftPath Float @default(0.35)
  featureVideoEditorForAll Boolean @default(false)
  welcomeVideoUrl String?

  // Superadmin-curated content for the public /demo preview, keyed by view:
  // { "PICDRIFT": { postIds: string[], assetIds: string[] }, "VISIONLIGHT": {...} }
  demoConfig Json?

  updatedAt DateTime @updatedAt
}

model Post {
  id                String   @id @default(uuid())
  userId            String
  title             String?
  prompt            String
  enhancedPrompt    String?
  imageReference    String?
  mediaType         String?
  mediaUrl          String?
  mediaProvider     String?
  generatedEndFrame String?
  status            String   @default("NEW")
  platform          String?
  script            Json?
  generationParams  Json?
  progress          Int      @default(0)
  error             String?
  generationStep    String?
  requiresApproval  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(uuid())
  userId      String
  url         String
  proxyUrl    String?  // Lightweight proxy video URL for editing
  hlsUrl      String?  // HLS stream URL (.m3u8)
  spriteSheetUrl String? // Timeline thumbnail sprite sheet URL
  aspectRatio String
  type        String   @default("IMAGE")
  sizeBytes   Int?     // Stored object size for tenant-level storage quota accounting
  createdAt   DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  originalAssetId String?
  originalAsset   Asset?  @relation("AssetHistory", fields: [originalAssetId], references: [id])
  variations      Asset[] @relation("AssetHistory")
}

model BrandConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  companyName    String?
  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ROIMetrics {
  id             String   @id @default(uuid())
  userId         String   @unique
  postsCreated   Int      @default(0)
  timeSaved      Int      @default(0)
  mediaGenerated Int      @default(0)
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditRequest {
  id        String   @id @default(uuid())
  userId    String
  email     String
  name      String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresetPrompt {
  id        String   @id @default(uuid())
  name      String
  prompt    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global presets isolated to the asset-library editor (PicFX + Convert tabs).
// Kept in a separate table so editor PromptFX never mixes with the shared
// PresetPrompt presets used by the dashboard panels and 3DX tab.
model EditorPresetPrompt {
  id        String   @id @default(uuid())
  name      String
  prompt    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ByokRenderUsage {
  id             String   @id @default(uuid())
  organizationId String
  usageDate      DateTime
  count          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, usageDate])
  @@index([usageDate])
}

model WebhookEvent {
  id             String   @id @default(uuid())
  provider       String
  eventKey       String
  eventType      String?
  organizationId String?
  payload        Json?
  status         String   @default("RECEIVED")
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, eventKey])
  @@index([organizationId])
}

model OrganizationEntitlement {
  id                  String   @id @default(uuid())
  organizationId      String   @unique
  packageCode         String
  status              String   @default("ACTIVE")
  wixOrderId          String?
  wixTransactionId    String?
  customerEmail       String?
  activatedAt         DateTime?
  expiresAt           DateTime?
  lastWebhookAt       DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// Rotation3D — interactive 360° product spins. Managed studio (view "ROTATION3D").
// Brands upload source images; the team uploads a rendered video that the pipeline
// turns into a frame manifest (Rot3dSpin) the public player scrubs. All additive.
// ─────────────────────────────────────────────────────────────────────────────

model Rot3dProduct {
  id              String   @id @default(uuid())
  organizationId  String
  slug            String
  name            String
  status          String   @default("DRAFT") // DRAFT | PROCESSING | READY | PUBLISHED | ARCHIVED
  defaultFrame    Int      @default(0)
  background      String? // "transparent" | hex
  ctaPrimary      Json? // { label, url } — e.g. "Next"
  ctaSecondary    Json? // { label, url } — e.g. "Previous"
  order           Int      @default(0)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceImages Rot3dSourceImage[]
  videos       Rot3dVideo[]
  spin         Rot3dSpin?
  embed        Rot3dEmbed?
  events       Rot3dEvent[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Rot3dSourceImage {
  id               String   @id @default(uuid())
  organizationId   String
  productId        String?
  url              String
  angleLabel       String?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Rot3dProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([productId])
}

model Rot3dVideo {
  id               String   @id @default(uuid())
  productId        String
  url              String
  status           String   @default("UPLOADED") // UPLOADED | PROCESSING | DONE | FAILED
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  product Rot3dProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Rot3dSpin {
  id         String   @id @default(uuid())
  productId  String   @unique
  frameCount Int
  manifest   Json // { frames: string[], defaultFrame, resolutions }
  status     String   @default("READY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Rot3dProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Rot3dEmbed {
  id             String   @id @default(uuid())
  productId      String   @unique
  token          String   @unique
  allowedDomains String[]
  createdAt      DateTime @default(now())

  product Rot3dProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Rot3dEvent {
  id             String   @id @default(uuid())
  organizationId String
  productId      String
  type           String // VIEW | ROTATE | ZOOM | CTA_CLICK
  meta           Json?
  ts             DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Rot3dProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([organizationId, ts])
}
