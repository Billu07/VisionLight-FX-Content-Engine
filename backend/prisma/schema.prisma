generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String  @id @default(uuid())
  name             String
  isActive         Boolean @default(true)
  isDefault        Boolean @default(false)
  provisioningSource String @default("MANUAL") // MANUAL | BYOK
  entitlementCode    String? // BYOK_TRIAL | PD_APP | VFX_APP | PD_STUDIO | VFX_STUDIO | VFX_STUDIO_AGENCY
  routingDomain      String?
  adminPanelLocked   Boolean @default(false)
  renderDailyLimit   Int?
  storageRetentionDays Int?
  provisioningStatus String  @default("READY") // READY | PENDING | ERROR
  tenantPlan       String  @default("PAID")
  trialEndsAt      DateTime?
  maxUsers         Int     @default(5)
  maxProjectsTotal Int     @default(20)
  maxStorageMb     Int     @default(10240) // Platform tenant storage limit in MB for the entire organization (default: 10GB)

  // Custom API Keys
  falApiKey    String?
  openaiApiKey String?
  kieApiKey    String?

  // Pricing Settings (Tenant specific)
  pricePicDrift_5s       Float @default(0.35)
  pricePicDrift_10s      Float @default(0.7)
  pricePicDrift_Plus_5s  Float @default(0.56)
  pricePicDrift_Plus_10s Float @default(1.12)

  pricePicFX_Standard Float @default(0.08)
  pricePicFX_Carousel Float @default(0.2)
  pricePicFX_Batch    Float @default(0.08)

  priceEditor_Pro     Float @default(0.1)
  priceEditor_Enhance Float @default(0.12)
  priceEditor_Convert Float @default(0.08)

  priceVideoFX1_10s Float @default(0.2)
  priceVideoFX1_15s Float @default(0.3)

  priceVideoFX2_4s   Float @default(1.21)
  priceVideoFX2_8s   Float @default(2.42)
  priceVideoFX2_12s  Float @default(3.63)

  priceVideoFX3_4s   Float @default(1.6)
  priceVideoFX3_6s   Float @default(2.4)
  priceVideoFX3_8s   Float @default(3.2)

  priceAsset_DriftPath Float @default(0.35)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfigs   BrandConfig[]
  roiMetrics     ROIMetrics[]
  creditRequests CreditRequest[]
  renderUsages      ByokRenderUsage[]
  webhookEvents     WebhookEvent[]
  entitlement       OrganizationEntitlement?
}

model User {
  id         String  @id @default(uuid())
  authUserId String?
  email      String
  name       String?

  creditsPicDrift     Float @default(10)
  creditsPicDriftPlus Float @default(10)
  creditsImageFX      Float @default(10)
  creditsVideoFX1     Float @default(10)
  creditsVideoFX2     Float @default(10)
  creditsVideoFX3     Float @default(10)

  creditBalance Float @default(20)

  creditSystem String   @default("COMMERCIAL")
  isDemo       Boolean  @default(false)
  role         String   @default("USER") // SUPERADMIN, ADMIN, USER
  view         String   @default("VISIONLIGHT")
  maxProjects  Int      @default(3)
  seatLocked   Boolean  @default(false)
  adminNotes   String?
  promptFx     Json?    // Stores the user's custom PromptFX setups [{ name: string, prompt: string }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projects       Project[]
  posts          Post[]
  assets         Asset[]
  brandConfig    BrandConfig?
  roiMetrics     ROIMetrics?
  creditRequests CreditRequest[]
  storyboard     Json?

  @@index([authUserId])
  @@index([email])
}

model Project {
  id         String   @id @default(uuid())
  userId     String
  name       String
  storyboard Json?
  editorState Json?   // Stores FullscreenVideoEditor sequences and audio tracks
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  Post[]
  assets Asset[]
}

model GlobalSettings {
  id String @id @default("singleton")

  pricePicDrift_5s       Float @default(0.35)
  pricePicDrift_10s      Float @default(0.7)
  pricePicDrift_Plus_5s  Float @default(0.56)
  pricePicDrift_Plus_10s Float @default(1.12)

  pricePicFX_Standard Float @default(0.08)
  pricePicFX_Carousel Float @default(0.2)
  pricePicFX_Batch    Float @default(0.08)

  priceEditor_Pro     Float @default(0.1)
  priceEditor_Enhance Float @default(0.12)
  priceEditor_Convert Float @default(0.08)

  priceVideoFX1_10s Float @default(0.2)
  priceVideoFX1_15s Float @default(0.3)

  priceVideoFX2_4s  Float @default(1.21)
  priceVideoFX2_8s  Float @default(2.42)
  priceVideoFX2_12s Float @default(3.63)

  priceVideoFX3_4s Float @default(1.6)
  priceVideoFX3_6s Float @default(2.4)
  priceVideoFX3_8s Float @default(3.2)

  priceAsset_DriftPath Float @default(0.35)
  featureVideoEditorForAll Boolean @default(false)
  welcomeVideoUrl String?

  updatedAt DateTime @updatedAt
}

model Post {
  id                String   @id @default(uuid())
  userId            String
  title             String?
  prompt            String
  enhancedPrompt    String?
  imageReference    String?
  mediaType         String?
  mediaUrl          String?
  mediaProvider     String?
  generatedEndFrame String?
  status            String   @default("NEW")
  platform          String?
  script            Json?
  generationParams  Json?
  progress          Int      @default(0)
  error             String?
  generationStep    String?
  requiresApproval  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(uuid())
  userId      String
  url         String
  proxyUrl    String?  // Lightweight proxy video URL for editing
  hlsUrl      String?  // HLS stream URL (.m3u8)
  spriteSheetUrl String? // Timeline thumbnail sprite sheet URL
  aspectRatio String
  type        String   @default("IMAGE")
  sizeBytes   Int?     // Stored object size for tenant-level storage quota accounting
  createdAt   DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  originalAssetId String?
  originalAsset   Asset?  @relation("AssetHistory", fields: [originalAssetId], references: [id])
  variations      Asset[] @relation("AssetHistory")
}

model BrandConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  companyName    String?
  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ROIMetrics {
  id             String   @id @default(uuid())
  userId         String   @unique
  postsCreated   Int      @default(0)
  timeSaved      Int      @default(0)
  mediaGenerated Int      @default(0)
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditRequest {
  id        String   @id @default(uuid())
  userId    String
  email     String
  name      String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresetPrompt {
  id        String   @id @default(uuid())
  name      String
  prompt    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ByokRenderUsage {
  id             String   @id @default(uuid())
  organizationId String
  usageDate      DateTime
  count          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, usageDate])
  @@index([usageDate])
}

model WebhookEvent {
  id             String   @id @default(uuid())
  provider       String
  eventKey       String
  eventType      String?
  organizationId String?
  payload        Json?
  status         String   @default("RECEIVED")
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, eventKey])
  @@index([organizationId])
}

model OrganizationEntitlement {
  id                  String   @id @default(uuid())
  organizationId      String   @unique
  packageCode         String
  status              String   @default("ACTIVE")
  wixOrderId          String?
  wixTransactionId    String?
  customerEmail       String?
  activatedAt         DateTime?
  expiresAt           DateTime?
  lastWebhookAt       DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
